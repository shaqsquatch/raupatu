      room.seats[slot] = {pid:slot, name:n, addr:wallet.addr, joined:true, paid:true, txHash};
      room.pool = (room.pool||0) + roomStake;
      await saveRoom(c, room);
      setTxStatus("done");
      onEnterRoom({code:c, myPid:slot, myName:n, premium:true, stakeUsd:roomStake, treasury:room.treasury});
