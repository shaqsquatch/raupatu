// ═══════════════════════════════════════════════════════════════════════════
// PLAYER BOX
// ═══════════════════════════════════════════════════════════════════════════
function PlayerBox({player,isActiveTurn,selCard,mode,frozenPiles,myPid,onClick}){
  const C=SEAT[player.id%4]; const top=topOf(player.pile);
  const frozen=frozenPiles.includes(player.id),isOpp=player.id!==myPid;
  const matches=selCard&&top&&top.r===selCard.r;
  const canSteal=selCard&&matches&&isOpp&&mode!=="place"&&!frozen;
  const canPlace=selCard&&!frozen&&mode!=="steal"&&!(matches&&isOpp);
  const blocked=selCard&&frozen; const clickable=canSteal||canPlace;
  const glow=canSteal?"0 0 20px 7px rgba(16,185,129,.8),0 0 0 2px #10b981":canPlace?"0 0 16px 6px rgba(59,130,246,.65),0 0 0 2px #3b82f6":blocked?"0 0 14px 5px rgba(220,38,38,.5)":isActiveTurn?"0 0 10px 4px rgba(251,191,36,.3)":"none";
  return(
    <div onClick={clickable?onClick:undefined} style={{background:C.bg,borderRadius:16,padding:"8px 10px",
      border:blocked?"3px solid #dc2626":`3px solid ${C.ring}`,cursor:clickable?"pointer":"default",
      display:"flex",flexDirection:"column",alignItems:"center",gap:5,boxShadow:glow,
      transition:"box-shadow .2s,border-color .2s",minWidth:88,position:"relative"}}>
      {isActiveTurn&&<div style={{position:"absolute",top:-9,left:"50%",transform:"translateX(-50%)",background:"#d97706",borderRadius:8,padding:"1px 8px",fontSize:8,fontWeight:900,color:"#fff",whiteSpace:"nowrap",border:"2px solid #fbbf24"}}>⚡ TURN</div>}
      <div style={{textAlign:"center"}}>
        <div style={{fontSize:10,fontWeight:700,color:C.label}}>{player.name}</div>
        <div style={{fontSize:20,fontWeight:900,color:"#34d399",lineHeight:1}}>{player.hand.length}</div>
        <div style={{fontSize:7,color:"#6b7280"}}>in hand</div>
      </div>
      <div style={{position:"relative"}}>
        {top?<PCard card={top} tiny greenGlow={canSteal} blueGlow={canPlace&&!canSteal} onClick={clickable?onClick:undefined}/>
          :<div style={{width:36,height:52,borderRadius:8,border:"2px dashed rgba(255,255,255,.2)",display:"flex",alignItems:"center",justifyContent:"center",color:"rgba(255,255,255,.25)",fontSize:18}}>+</div>}
        {(canSteal||canPlace)&&<div style={{position:"absolute",inset:-3,borderRadius:11,pointerEvents:"none",boxShadow:canSteal?"0 0 18px 8px rgba(16,185,129,.85)":"0 0 14px 6px rgba(59,130,246,.75)",animation:"gpulse 1s ease-in-out infinite"}}/>}
        {blocked&&<div style={{position:"absolute",inset:0,borderRadius:8,pointerEvents:"none",background:"rgba(220,38,38,.35)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:16}}>🚫</div>}
      </div>
      <div style={{fontSize:8,color:"#fcd34d"}}>{player.pile.length} in pile</div>
    </div>
  );
}

function GameLog({lines}){
  const ref=useRef();
  useEffect(()=>{if(ref.current)ref.current.scrollTop=ref.current.scrollHeight;},[lines]);
  return(<div ref={ref} style={{height:56,overflowY:"auto",borderRadius:10,border:"2px solid #78350f",background:"rgba(0,0,0,.7)",padding:"4px 8px",fontFamily:"monospace",fontSize:9.5}}>
    {lines.map((l,i)=><div key={i} style={{color:"#fef3c7",lineHeight:1.55}}>{l}</div>)}
  </div>);
}

