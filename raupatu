    const room = await loadRoom(c);
    if(!room)           return setBusy(false)||setErr("Room not found");
    if(!room.premium)   return setBusy(false)||setErr("Not a premium room");
    if(room.started)    return setBusy(false)||setErr("Game already started");
    const slot = room.seats.findIndex(s=>s===null);
    if(slot===-1)       return setBusy(false)||setErr("Room is full");
    const roomStake = room.stakeUsd || 1;
    setStake(roomStake); // match host's stake
    setTxStatus("pending");
    try{
