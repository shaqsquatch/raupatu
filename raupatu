// WAITING ROOM
// ═══════════════════════════════════════════════════════════════════════════
function WaitingRoom({session,onStart,onLeave}){
  const {code,myPid,premium}=session;
  const [room,setRoom]=useState(null); const [err,setErr]=useState(""); const [busy,setBusy]=useState(false);
  useEffect(()=>{
    const tick=async()=>{ const r=await loadRoom(code); if(r){setRoom(r); if(r.started&&r.game)onStart(r.game);} };
    tick(); const id=setInterval(tick,2000); return()=>clearInterval(id);
  },[code]);
  async function startGame(){
    const r=await loadRoom(code); if(!r)return setErr("Room gone");
    const names=r.seats.filter(Boolean).map(s=>s.name); if(names.length<2)return setErr("Need 2+ players");
    const game=freshGame(names); r.started=true; r.game=game; setBusy(true);
    await saveRoom(code,r); onStart(game); setBusy(false);
  }
  const seats=room?room.seats:[null,null,null,null];
  const filled=seats.filter(Boolean);
  const pool=room?.pool||0;
  return(
    <div style={{minHeight:"100vh",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:24,gap:16}}>
      <div style={{textAlign:"center"}}>
        <div style={{fontSize:22,fontWeight:900,color:premium?"#be123c":"#059669",textShadow:`0 0 20px ${premium?"rgba(190,18,60,.5)":"rgba(5,150,105,.5)"}`}}>
          {premium?"💰 Premium Room":"🎮 Free Room"}
        </div>
        {premium&&<div style={{fontSize:13,color:"#34d399",marginTop:4}}>Prize Pool: ${pool} USDT equiv.</div>}
      </div>
      {/* code display */}
      <div style={{textAlign:"center",padding:"14px 32px",borderRadius:20,border:"3px solid #C9A84C",background:"rgba(0,0,0,.7)"}}>
        <div style={{fontSize:11,color:"#a16207",marginBottom:4}}>Share this code</div>
        <div style={{fontSize:44,fontWeight:900,letterSpacing:".3em",color:"#fbbf24",textShadow:"0 0 20px rgba(251,191,36,.6)"}}>{code}</div>
      </div>
      {/* seats */}
      <div style={{width:"100%",maxWidth:340,display:"flex",flexDirection:"column",gap:8}}>
        {[0,1,2,3].map(i=>{
          const s=seats[i];
          return(<div key={i} style={{display:"flex",alignItems:"center",gap:10,padding:"8px 14px",borderRadius:12,border:`2px solid ${s?SEAT[i].ring:"rgba(255,255,255,.1)"}`,background:s?SEAT[i].bg:"rgba(0,0,0,.3)"}}>
            <div style={{width:28,height:28,borderRadius:14,background:s?SEAT[i].ring:"rgba(255,255,255,.1)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:13,fontWeight:900,color:"#fff"}}>{i+1}</div>
            <div style={{flex:1}}>
              <div style={{fontSize:13,fontWeight:700,color:s?SEAT[i].label:"#6b7280"}}>{s?s.name:"Waiting…"}</div>
              {i===0&&s&&<div style={{fontSize:9,color:"#a16207"}}>Host {premium&&"· Holds pool"}</div>}
              {s&&s.pid===myPid&&<div style={{fontSize:9,color:"#34d399"}}>← You</div>}
              {premium&&s?.paid&&<div style={{fontSize:8,color:"#34d399"}}>✅ Staked</div>}
            </div>
            {s&&<div style={{fontSize:16}}>✓</div>}
          </div>);
        })}
      </div>
      {err&&<div style={{color:"#f87171",fontSize:11}}>{err}</div>}
      <div style={{display:"flex",gap:10}}>
        {myPid===0&&(
          <button onClick={startGame} disabled={busy||filled.length<2} style={{padding:"12px 28px",borderRadius:16,fontWeight:900,fontSize:15,border:"3px solid #fbbf24",background:"linear-gradient(135deg,#92400e,#d97706)",color:"#fff",cursor:filled.length<2?"not-allowed":"pointer",fontFamily:"inherit",opacity:(busy||filled.length<2)?.5:1,boxShadow:"0 0 14px 4px rgba(251,191,36,.3)"}}>
            🎮 Start ({filled.length}/4)
          </button>
        )}
        {myPid!==0&&<div style={{fontSize:11,color:"#a16207",padding:"10px 20px",borderRadius:12,border:"1px solid #78350f",background:"rgba(0,0,0,.4)"}}>⏳ Waiting for host…</div>}
        <button onClick={onLeave} style={{padding:"10px 18px",borderRadius:14,fontWeight:700,fontSize:12,border:"2px solid #6b7280",background:"rgba(0,0,0,.5)",color:"#9ca3af",cursor:"pointer",fontFamily:"inherit"}}>← Leave</button>
      </div>
      <div style={{fontSize:9,color:"#6b7280"}}>Polling every 2s…</div>
    </div>
  );
}

