// GAME TABLE
// ═══════════════════════════════════════════════════════════════════════════
function GameTable({initGame,session,onLeave}){
  const {code,myPid,premium}=session;
  const [G,setGLocal]=useState(initGame);
  const GRef=useRef(G); GRef.current=G;
  const [syncing,setSyncing]=useState(false);
  const myTurn=G.turn===myPid&&G.phase==="play";

  const pushState=useCallback(async newG=>{
    setSyncing(true);
    try{ const room=await loadRoom(code); if(room){room.game=newG;await saveRoom(code,room);} }catch{}
    setSyncing(false);
  },[code]);

  useEffect(()=>{
    if(myTurn)return;
    const id=setInterval(async()=>{
      const room=await loadRoom(code); if(!room?.game)return; const remote=room.game;
      if(remote.turn!==GRef.current.turn||remote.phase!==GRef.current.phase||JSON.stringify(remote.log)!==JSON.stringify(GRef.current.log))
        setGLocal(remote);
    },2000);
    return()=>clearInterval(id);
  },[code,myTurn]);

  function apply(fn){ setGLocal(prev=>{ const next=fn(prev); pushState(next); return next; }); }

  function selectCard(i){ if(!myTurn||G.mode==="place")return; setGLocal(g=>({...g,sel:g.sel===i?null:i})); }

  function clickBox(targetId){
    if(!myTurn||G.sel===null)return;
    apply(prev=>{
      if(prev.sel===null||prev.sel>=prev.players[myPid].hand.length)return prev;
      const card=prev.players[myPid].hand[prev.sel];
      const target=prev.players[targetId]; const top=topOf(target.pile);
      const frozen=prev.frozenPiles.includes(targetId),isOpp=targetId!==myPid;
      const matches=top&&top.r===card.r;
      if(isOpp&&matches&&prev.mode!=="place"&&!frozen){
        const ps=cloneP(prev.players); ps[myPid].hand.splice(prev.sel,1);
        const stolen=[...ps[targetId].pile]; ps[myPid].pile=[...ps[myPid].pile,...stolen];
        ps[targetId].pile=[];
        return{...prev,players:ps,sel:null,mode:"steal",stealsCount:prev.stealsCount+1,cardsUsed:prev.cardsUsed+1,
          frozenPiles:[...prev.frozenPiles,targetId],
          log:[...prev.log,`🔥 ${prev.players[myPid].name} stole ${stolen.length} from ${target.name} with ${card.r}!`]};
      }
      if(prev.mode!=="steal"&&!frozen){
        const ps=cloneP(prev.players); ps[myPid].hand.splice(prev.sel,1); ps[targetId].pile.push(card);
        const{players:ps2,deck:d2}=fillHand(ps,prev.deck,myPid);
        const drew=ps2[myPid].hand.length-(ps[myPid].hand.length); // delta
        return maybeOver(nextTurn({...prev,players:ps2,deck:d2,
          log:[...prev.log,`📤 ${prev.players[myPid].name} placed ${card.r}${card.s} on ${target.name}'s pile. Drew ${drew} → hand ${ps2[myPid].hand.length}.`]},myPid));
      }
      if(frozen)return{...prev,sel:null,log:[...prev.log,`🚫 ${target.name}'s pile was just stolen!`]};
      return prev;
    });
  }

  function doEndTurn(){
    if(!myTurn||G.mode!=="steal")return;
    apply(prev=>{
      const before=prev.players[myPid].hand.length;
      const{players,deck}=fillHand(prev.players,prev.deck,myPid);
      const drew=players[myPid].hand.length-before;
      return maybeOver(nextTurn({...prev,players,deck,
        log:[...prev.log,`↩️ ${prev.players[myPid].name} ends turn. Drew ${drew} → hand ${players[myPid].hand.length}.`]},myPid));
    });
  }

  const me=G.players[myPid],others=G.players.filter(p=>p.id!==myPid);
  const selCard=G.sel!==null&&G.sel<(me?.hand.length??0)?me.hand[G.sel]:null;
  const canEnd=myTurn&&G.mode==="steal"&&G.sel===null;
  function handCardGlows(card){ if(G.mode==="place")return false; return G.players.filter(p=>p.id!==myPid).some(a=>{const t=topOf(a.pile);return t&&t.r===card.r&&!G.frozenPiles.includes(a.id);}); }

  let hint="";
  if(myTurn){
    if(selCard){
      const targets=G.players.filter(p=>p.id!==myPid).filter(a=>{const t=topOf(a.pile);return t&&t.r===selCard.r&&G.mode!=="place"&&!G.frozenPiles.includes(a.id);});
      if(G.mode==="steal") hint=targets.length?`🔥 Steal from ${targets.map(a=>a.name).join("/")} again — or End Turn to draw to 3`:`No more steal targets — End Turn to draw to 3`;
      else hint=targets.length?`Kua ōrite! STEAL ${targets.map(a=>a.name).join("/")} 🔥  OR  click any pile to PLACE`:"Click any pile to PLACE (draws to 3, ends turn)";
    }else if(G.mode==="steal") hint=`${G.stealsCount} steal${G.stealsCount>1?"s":""} done — select card to steal more, or End Turn`;
    else hint="Your turn — STEAL freely  OR  PLACE 1";
  }else if(G.phase==="play") hint=`⏳ ${G.players[G.turn]?.name}'s turn…`;

  const prizePool=premium?(G.players.length):0;

  return(
    <div style={{width:"100%",minHeight:"100vh",display:"flex",flexDirection:"column",fontFamily:"Georgia,serif",userSelect:"none",background:"radial-gradient(ellipse at 50% 35%,#1c4f1c 0%,#0e2d0e 55%,#061406 100%)",position:"relative",overflowX:"hidden"}}>
      <div style={{position:"fixed",inset:0,pointerEvents:"none",zIndex:0,backgroundImage:`repeating-linear-gradient(0deg,rgba(255,255,255,.008) 0,rgba(255,255,255,.008) 1px,transparent 1px,transparent 9px),repeating-linear-gradient(90deg,rgba(255,255,255,.008) 0,rgba(255,255,255,.008) 1px,transparent 1px,transparent 9px)`}}/>
      <div style={{position:"fixed",top:0,inset:"0 0 auto",height:6,zIndex:1,opacity:.5,background:"repeating-linear-gradient(90deg,#8B0000 0,#8B0000 20px,#C9A84C 20px,#C9A84C 40px)"}}/>
      <div style={{position:"fixed",bottom:0,inset:"auto 0 0",height:6,zIndex:1,opacity:.5,background:"repeating-linear-gradient(90deg,#C9A84C 0,#C9A84C 20px,#8B0000 20px,#8B0000 40px)"}}/>

      {G.phase==="over"&&(
        <div style={{position:"fixed",inset:0,zIndex:200,background:"rgba(0,0,0,.93)",display:"flex",alignItems:"center",justifyContent:"center"}}>
          <div style={{textAlign:"center",padding:"36px 44px",borderRadius:28,border:"4px solid #f59e0b",background:"linear-gradient(160deg,#180900,#2c1800)",maxWidth:380}}>
            <div style={{fontSize:56,marginBottom:12}}>{G.winner===me?.name?"🏆":G.winner==="Tie"?"🤝":"🤖"}</div>
            <div style={{fontSize:24,fontWeight:900,color:"#fbbf24",marginBottom:10,letterSpacing:".1em"}}>{G.winner===me?.name?"KO AU TE TOA!":G.winner==="Tie"?"HE ŌRITE!":G.winner+" WINS!"}</div>
            {premium&&G.winner!=="Tie"&&<div style={{fontSize:16,color:"#34d399",fontWeight:700,marginBottom:10}}>💰 Prize Pool: ${prizePool} → {G.winner}</div>}
            <div style={{color:"#fef3c7",lineHeight:2,fontSize:11,marginBottom:18}}>{G.players.map(p=>`${p.name}: ${p.pile.length} cards`).join("  ·  ")}</div>
            <button onClick={onLeave} style={{padding:"12px 36px",borderRadius:20,fontWeight:900,fontSize:16,border:"4px solid #f59e0b",background:"linear-gradient(135deg,#991b1b,#d97706)",color:"#fff",cursor:"pointer",fontFamily:"inherit"}}>← Menu</button>
          </div>
        </div>
      )}

      <div style={{position:"relative",zIndex:2,flex:1,display:"flex",flexDirection:"column",padding:"12px 12px 0",paddingBottom:140}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10,flexWrap:"wrap",gap:6}}>
          <div>
            <div style={{fontSize:18,fontWeight:900,letterSpacing:".15em",color:"#C9A84C",textShadow:"0 0 16px rgba(201,168,76,.75),3px 3px 0 #4a0000"}}>✦ RAUPATU ✦</div>
            <div style={{fontSize:8,color:"#fbbf24",letterSpacing:".12em"}}>
              {premium&&<span style={{color:"#fda4af",marginRight:6}}>💰 PREMIUM · ${prizePool} POOL</span>}
              ROOM: <b style={{color:"#fff",letterSpacing:".25em"}}>{code}</b>
              {syncing&&<span style={{color:"#fbbf24",marginLeft:6}}>↑</span>}
            </div>
          </div>
          <div style={{display:"flex",gap:8,alignItems:"center"}}>
            <div style={{fontSize:10,color:"#fcd34d",background:"rgba(0,0,0,.6)",padding:"3px 10px",borderRadius:10,border:"1px solid #78350f"}}>🃏 <b style={{color:"#fff"}}>{G.deck.length}</b></div>
            <div style={{fontSize:11,fontWeight:700,padding:"3px 12px",borderRadius:12,background:myTurn?"#065f46":"#4a1010",color:myTurn?"#fff":"#fca5a5"}}>{myTurn?"⚡ YOUR TURN":`⏳ ${G.players[G.turn]?.name}…`}</div>
            <button onClick={onLeave} style={{padding:"3px 10px",borderRadius:8,fontSize:10,fontWeight:700,border:"1px solid #6b7280",background:"rgba(0,0,0,.5)",color:"#9ca3af",cursor:"pointer",fontFamily:"inherit"}}>Leave</button>
          </div>
        </div>

        <div style={{display:"flex",justifyContent:"center",gap:14,marginBottom:10}}>
          {others.map(p=><PlayerBox key={p.id} player={p} isActiveTurn={G.turn===p.id} selCard={myTurn?selCard:null} mode={G.mode} frozenPiles={G.frozenPiles} myPid={myPid} onClick={()=>clickBox(p.id)}/>)}
        </div>

        <div style={{display:"flex",justifyContent:"center",alignItems:"center",gap:28,flex:1,minHeight:0,paddingBottom:8}}>
          {me&&<PlayerBox player={me} isActiveTurn={myTurn} selCard={myTurn?selCard:null} mode={G.mode} frozenPiles={G.frozenPiles} myPid={myPid} onClick={()=>clickBox(myPid)}/>}
          <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:5}}>
            <div style={{fontSize:9,color:"#fbbf24",fontWeight:700,letterSpacing:".1em"}}>DRAW PILE</div>
            <div style={{position:"relative",width:66,height:96}}>
              {G.deck.length>2&&<div style={{position:"absolute",width:58,height:84,top:8,left:8,borderRadius:9,border:"3px solid #78350f",background:"#1a3a5c",zIndex:0}}/>}
              {G.deck.length>1&&<div style={{position:"absolute",width:58,height:84,top:4,left:4,borderRadius:9,border:"3px solid #78350f",background:"#1c3d62",zIndex:1}}/>}
              <div style={{position:"absolute",top:0,left:0,zIndex:2}}>{G.deck.length>0?<PCard faceDown/>:<div style={{width:58,height:84,borderRadius:9,border:"2px dashed #a16207",display:"flex",alignItems:"center",justifyContent:"center",color:"#a16207",fontSize:10,opacity:.5}}>EMPTY</div>}</div>
            </div>
            <div style={{fontSize:9,color:"#fcd34d"}}>{G.deck.length} cards</div>
          </div>
          {myTurn&&G.cardsUsed>0&&<div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:3}}><div style={{fontSize:8,color:"#9ca3af"}}>THIS TURN</div><div style={{fontSize:24,fontWeight:900,color:"#93c5fd",lineHeight:1}}>{G.cardsUsed}</div><div style={{fontSize:9,color:"#34d399"}}>→draw {G.cardsUsed}</div></div>}
        </div>

        <div style={{textAlign:"center",minHeight:24,marginBottom:6}}>{hint&&<div style={{display:"inline-block",fontSize:10,color:"#fef3c7",background:"rgba(0,0,0,.7)",padding:"3px 14px",borderRadius:10,border:"1px solid #78350f"}}>{hint}</div>}</div>

        {canEnd&&<div style={{display:"flex",justifyContent:"center",marginBottom:8}}><button onClick={doEndTurn} style={{padding:"9px 28px",borderRadius:18,fontWeight:900,fontSize:13,border:"3px solid #fbbf24",background:"linear-gradient(135deg,#92400e,#d97706)",color:"#fff",cursor:"pointer",fontFamily:"inherit",boxShadow:"0 0 14px 5px rgba(251,191,36,.35)"}}>↩️ Mutu tō huri — End Turn &amp; Draw to 3</button></div>}

        <div style={{display:"flex",gap:6,marginBottom:6}}>{G.players.map(p=><div key={p.id} style={{flex:1,borderRadius:10,padding:"5px 6px",border:`2px solid ${SEAT[p.id%4].ring}`,background:"rgba(0,0,0,.45)",textAlign:"center"}}><div style={{fontSize:8,color:"#d1d5db",fontWeight:700}}>{p.name}{p.id===myPid?" ★":""}</div><div style={{fontSize:14,color:"#34d399",fontWeight:900}}>{p.hand.length}</div><div style={{fontSize:7,color:"#6b7280"}}>in hand</div></div>)}</div>

        <GameLog lines={G.log}/>
      </div>

      <div style={{position:"fixed",bottom:0,left:0,right:0,zIndex:10}}>
        <div style={{display:"flex",justifyContent:"center",marginBottom:4}}>
          <div style={{fontSize:9,color:SEAT[myPid%4].label,letterSpacing:".12em",fontWeight:700,background:"rgba(0,0,0,.8)",padding:"2px 12px",borderRadius:8,border:`1px solid ${SEAT[myPid%4].ring}`}}>
            YOUR HAND ({me?.hand.length??0})
            {G.mode==="place"&&<span style={{color:"#f87171",marginLeft:6}}>· Placed — turn over</span>}
            {G.mode==="steal"&&<span style={{color:"#34d399",marginLeft:6}}>· {G.stealsCount} steal{G.stealsCount>1?"s":""} — steal more or End Turn</span>}
            {!G.mode&&myTurn&&<span style={{color:"#fbbf24",marginLeft:6}}>· Steal freely OR place 1</span>}
            {!myTurn&&<span style={{color:"#6b7280",marginLeft:6}}>· Waiting…</span>}
          </div>
        </div>
        <div style={{height:18,background:"linear-gradient(180deg,#3b1f0a 0%,#5c2d0e 40%,#7a3d14 100%)",borderTop:"3px solid #a0522d",boxShadow:"0 -4px 18px rgba(0,0,0,.7),inset 0 2px 6px rgba(255,200,100,.1)",position:"relative"}}>
          {[12,28,48,68,84].map(pct=><div key={pct} style={{position:"absolute",top:3,bottom:3,left:`${pct}%`,width:1,background:"rgba(0,0,0,.15)",borderRadius:1}}/>)}
        </div>
        <div style={{background:"linear-gradient(180deg,#1a0d04 0%,#110800 100%)",paddingBottom:10,display:"flex",justifyContent:"center",boxShadow:"inset 0 4px 14px rgba(0,0,0,.8)"}}>
          <div style={{display:"flex",gap:10,paddingLeft:16,paddingRight:16}}>
            {(me?.hand??[]).map((card,i)=><div key={card.id} style={{marginTop:G.sel===i?-56:-28,transition:"margin-top .18s ease"}}><PCard card={card} greenGlow={G.sel===null&&myTurn&&handCardGlows(card)} onClick={myTurn?()=>selectCard(i):undefined}/></div>)}
            {Array.from({length:Math.max(0,3-(me?.hand.length??0))}).map((_,i)=><div key={i} style={{width:58,height:84,marginTop:-28,borderRadius:9,border:"2px dashed rgba(100,200,100,.07)"}}/>)}
          </div>
        </div>
      </div>
      <style>{`@keyframes gpulse{0%,100%{opacity:1}50%{opacity:.3}}`}</style>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════════════════
// TUTORIAL GAME  (single-player vs 3 AI, contextual overlays)
// ═══════════════════════════════════════════════════════════════════════════
const TUT_STEPS = [
  { id:"welcome",  title:"Tūturu mai! Welcome to Raupatu 🎴",
    body:"This quick tutorial will teach you how to play against AI opponents. Watch for the glowing hints — they'll guide every move.",
    btn:"Let's play!", phase:"pre" },
  { id:"select",   title:"Select a card from your hand ↓",
    body:"Your cards are hidden under the table edge. Tap one to pick it up — it will rise above the table.",
    btn:null, phase:"need_select" },
  { id:"steal",    title:"🔥 Raupatuhia! You can steal!",
    body:"A green glow means your card matches an opponent's top pile card. Tap their box to steal their entire pile!",
    btn:null, phase:"can_steal" },
  { id:"place",    title:"📤 Place a card instead",
    body:"No steal available? Tap any player box to place your card on their pile. Placing ends your turn immediately.",
    btn:null, phase:"can_place" },
  { id:"endturn",  title:"↩️ End your steal turn",
    body:"You've stolen — now hit End Turn to draw back the same number of cards you used.",
    btn:null, phase:"end_turn" },
  { id:"ai_watch", title:"🤖 Watch the AI play",
    body:"AI opponents steal freely when they can, otherwise place on their own pile. Study their moves!",
    btn:null, phase:"ai_turn" },
  { id:"done",     title:"Kia ora! You've got it 🏆",
    body:"You know how to steal, place, and draw back. Head to the main menu to play for real — or keep going here!",
    btn:"Go to Menu", phase:"done" },
];

function TutorialGame({ onDone, onSkip }) {
  const [G, setG] = useState(() => freshGame(["You","Hine-AI","Tūhoe-AI","Rangi-AI"]));
  const GRef = useRef(G); GRef.current = G;

  // Which tutorial card to show
  const [tipId, setTipId]   = useState("welcome");
  const [milestones, setMS] = useState({ stolen:false, placed:false, endedTurn:false, aiSeen:false });
  const MSRef = useRef(milestones); MSRef.current = milestones;

  const myPid  = 0;
  const me     = G.players[0];
  const myTurn = G.turn === 0 && G.phase === "play";

  // Derive contextual tip
  useEffect(() => {
    if (tipId === "welcome" || tipId === "done") return;
    if (G.phase === "over") { setTipId("done"); return; }
    if (G.turn !== 0) { if (!MSRef.current.aiSeen) { setTipId("ai_watch"); setMS(m=>({...m,aiSeen:true})); } return; }
    if (G.mode === "steal" && G.cardsUsed > 0 && G.sel === null) { setTipId("endturn"); return; }
    if (G.sel === null) { setTipId("select"); return; }
    const selCard = me.hand[G.sel];
    const hasSteal = G.players.slice(1).some(a=>{ const t=topOf(a.pile); return t&&t.r===selCard?.r&&!G.frozenPiles.includes(a.id); });
    if (hasSteal) { setTipId("steal"); return; }
    setTipId("place");
  }, [G.turn, G.phase, G.sel, G.mode, G.cardsUsed]);

  // AI turns
  useEffect(() => {
    if (G.turn === 0 || G.phase !== "play") return;
    const pid = G.turn;
    const t = setTimeout(() => {
      setG(prev => {
        if (prev.turn !== pid || prev.phase !== "play") return prev;
        const ps = cloneP(prev.players);
        let deck = [...prev.deck], used = 0, logs = [...prev.log], found = true;
        while (found) {
          found = false;
          for (let opp = 0; opp < 4; opp++) {
            if (opp === pid) continue;
            const top = topOf(ps[opp].pile); if (!top) continue;
            const mi = ps[pid].hand.findIndex(c => c.r === top.r); if (mi === -1) continue;
            const card = ps[pid].hand.splice(mi, 1)[0];
            const stolen = [...ps[opp].pile];
            ps[pid].pile = [...ps[pid].pile, ...stolen]; ps[opp].pile = [];
            used++;
            logs.push(`🤖 ${ps[pid].name} stole ${stolen.length} from ${ps[opp].name} with ${card.r}!`);
            found = true; break;
          }
        }
        if (!ps[pid].hand.length) { /* nothing to place */ }
        else if (used === 0) {
          const sorted = [...ps[pid].hand].sort((a,b)=>RV(a.r)-RV(b.r));
          const play = sorted[0];
          ps[pid].hand.splice(ps[pid].hand.findIndex(c=>c.id===play.id),1);
          ps[pid].pile.push(play); used++;
          logs.push(`🤖 ${ps[pid].name} places ${play.r}${play.s}`);
        }
        let drawn = 0;
        const before = ps[pid].hand.length;
        while (ps[pid].hand.length < 3 && deck.length) { ps[pid].hand.push(deck.shift()); drawn++; }
        if (drawn) logs.push(`🤖 ${ps[pid].name} drew ${drawn} → hand ${ps[pid].hand.length}.`);
        return maybeOver(nextTurn({...prev,players:ps,deck,log:logs}, pid));
      });
    }, 1100 + pid * 200);
    return () => clearTimeout(t);
  }, [G.turn, G.phase]);

  // Human actions
  function selectCard(i) {
    if (!myTurn || G.mode === "place") return;
    setG(g => ({...g, sel: g.sel===i ? null : i}));
  }
  function clickBox(targetId) {
    if (!myTurn || G.sel === null) return;
    setG(prev => {
      if (prev.sel === null || prev.sel >= prev.players[0].hand.length) return prev;
      const card = prev.players[0].hand[prev.sel];
      const target = prev.players[targetId];
      const top = topOf(target.pile);
      const frozen = prev.frozenPiles.includes(targetId);
      const isOpp = targetId !== 0;
      const matches = top && top.r === card.r;
      if (isOpp && matches && prev.mode !== "place" && !frozen) {
        const ps = cloneP(prev.players);
        ps[0].hand.splice(prev.sel, 1);
        const stolen = [...ps[targetId].pile];
        ps[0].pile = [...ps[0].pile, ...stolen]; ps[targetId].pile = [];
        setMS(m=>({...m, stolen:true}));
        return {...prev,players:ps,sel:null,mode:"steal",stealsCount:prev.stealsCount+1,cardsUsed:prev.cardsUsed+1,
          frozenPiles:[...prev.frozenPiles,targetId],
          log:[...prev.log,`🔥 Raupatuhia! You stole ${stolen.length} from ${target.name} with ${card.r}!`]};
      }
      if (prev.mode !== "steal" && !frozen) {
        const ps = cloneP(prev.players);
        ps[0].hand.splice(prev.sel, 1); ps[targetId].pile.push(card);
        const {players:ps2, deck:d2} = fillHand(ps, prev.deck, 0);
        const drew = ps2[0].hand.length - ps[0].hand.length;
        setMS(m=>({...m, placed:true}));
        return maybeOver(nextTurn({...prev,players:ps2,deck:d2,
          log:[...prev.log,`📤 You placed ${card.r}${card.s} on ${target.name==="You"?"your pile":target.name+"'s pile"}. Drew ${drew} → hand ${ps2[0].hand.length}.`]},0));
      }
      if (frozen) return {...prev,sel:null,log:[...prev.log,`🚫 ${target.name}'s pile just stolen — can't place there!`]};
      return prev;
    });
  }
  function doEndTurn() {
    if (!myTurn || G.mode !== "steal") return;
    setG(prev => {
      const before = prev.players[0].hand.length;
      const {players,deck} = fillHand(prev.players, prev.deck, 0);
      const drew = players[0].hand.length - before;
      setMS(m=>({...m,endedTurn:true}));
      return maybeOver(nextTurn({...prev,players,deck,
        log:[...prev.log,`↩️ You drew ${drew} → hand ${players[0].hand.length}. Next player's turn.`]},0));
    });
  }

  const selCard = G.sel !== null && G.sel < me.hand.length ? me.hand[G.sel] : null;
  const canEnd  = myTurn && G.mode==="steal" && G.sel===null;
  const handCardGlows = card => G.mode!=="place" && G.players.slice(1).some(a=>{const t=topOf(a.pile);return t&&t.r===card.r&&!G.frozenPiles.includes(a.id);});

  const tip = TUT_STEPS.find(s=>s.id===tipId) || TUT_STEPS[1];
  const accentColor = tipId==="steal"?"#10b981":tipId==="place"?"#3b82f6":tipId==="endturn"?"#f59e0b":"#C9A84C";

  const felt = {width:"100%",minHeight:"100vh",display:"flex",flexDirection:"column",fontFamily:"Georgia,serif",userSelect:"none",
    background:"radial-gradient(ellipse at 50% 35%,#1c4f1c 0%,#0e2d0e 55%,#061406 100%)",position:"relative",overflowX:"hidden"};

  return (
    <div style={felt}>
      {/* felt + borders */}
      <div style={{position:"fixed",inset:0,pointerEvents:"none",zIndex:0,backgroundImage:`repeating-linear-gradient(0deg,rgba(255,255,255,.008) 0,rgba(255,255,255,.008) 1px,transparent 1px,transparent 9px),repeating-linear-gradient(90deg,rgba(255,255,255,.008) 0,rgba(255,255,255,.008) 1px,transparent 1px,transparent 9px)`}}/>
      <div style={{position:"fixed",top:0,inset:"0 0 auto",height:6,zIndex:1,opacity:.5,background:"repeating-linear-gradient(90deg,#8B0000 0,#8B0000 20px,#C9A84C 20px,#C9A84C 40px)"}}/>
      <div style={{position:"fixed",bottom:0,inset:"auto 0 0",height:6,zIndex:1,opacity:.5,background:"repeating-linear-gradient(90deg,#C9A84C 0,#C9A84C 20px,#8B0000 20px,#8B0000 40px)"}}/>

      {/* WELCOME MODAL */}
      {tipId==="welcome" && (
        <div style={{position:"fixed",inset:0,zIndex:300,background:"rgba(0,0,0,.88)",display:"flex",alignItems:"center",justifyContent:"center",padding:20}}>
          <div style={{maxWidth:400,width:"100%",borderRadius:24,border:"3px solid #C9A84C",background:"linear-gradient(160deg,#0c1a0c,#111a08)",padding:"32px 28px",textAlign:"center"}}>
            <div style={{fontSize:52,marginBottom:12}}>🎴</div>
            <div style={{fontSize:22,fontWeight:900,color:"#C9A84C",letterSpacing:".12em",marginBottom:8}}>TŪTURU MAI!</div>
            <div style={{fontSize:13,color:"#fbbf24",marginBottom:6}}>Welcome to Raupatu</div>
            <div style={{fontSize:11,color:"#d1d5db",lineHeight:1.7,marginBottom:24}}>
              This tutorial teaches you the game against AI opponents.<br/>
              Watch for <b style={{color:"#10b981"}}>green glows</b> (steal!) and <b style={{color:"#3b82f6"}}>blue glows</b> (place).<br/>
              The hints up top will guide each move.
            </div>
            <div style={{display:"flex",gap:10,justifyContent:"center"}}>
              <button onClick={()=>setTipId("select")}
                style={{padding:"12px 28px",borderRadius:16,fontWeight:900,fontSize:14,border:"3px solid #C9A84C",background:"linear-gradient(135deg,#92400e,#C9A84C)",color:"#fff",cursor:"pointer",fontFamily:"inherit"}}>
                🎮 Let's Play!
              </button>
              <button onClick={onSkip}
                style={{padding:"12px 20px",borderRadius:16,fontWeight:700,fontSize:13,border:"2px solid #6b7280",background:"rgba(0,0,0,.5)",color:"#9ca3af",cursor:"pointer",fontFamily:"inherit"}}>
                Skip →
              </button>
            </div>
          </div>
        </div>
      )}

      {/* DONE MODAL */}
      {tipId==="done" && (
        <div style={{position:"fixed",inset:0,zIndex:300,background:"rgba(0,0,0,.9)",display:"flex",alignItems:"center",justifyContent:"center",padding:20}}>
          <div style={{maxWidth:380,width:"100%",borderRadius:24,border:"3px solid #059669",background:"linear-gradient(160deg,#012818,#031f10)",padding:"32px 28px",textAlign:"center"}}>
            <div style={{fontSize:52,marginBottom:10}}>🏆</div>
            <div style={{fontSize:20,fontWeight:900,color:"#6ee7b7",marginBottom:8}}>
              {G.winner==="You" ? "KO AU TE TOA! You won!" : G.winner==="Tie" ? "He ōrite! A tie!" : `${G.winner} won this one!`}
            </div>
            <div style={{fontSize:11,color:"#d1d5db",lineHeight:1.7,marginBottom:8}}>
              {G.players.map(p=>`${p.name}: ${p.pile.length} cards`).join("  ·  ")}
            </div>
            <div style={{fontSize:12,color:"#6ee7b7",marginBottom:22}}>Kia ora! You know how to play. Ready for the real thing?</div>
            <div style={{display:"flex",gap:10,justifyContent:"center",flexWrap:"wrap"}}>
              <button onClick={onDone}
                style={{padding:"12px 24px",borderRadius:16,fontWeight:900,fontSize:14,border:"3px solid #059669",background:"linear-gradient(135deg,#065f46,#047857)",color:"#fff",cursor:"pointer",fontFamily:"inherit"}}>
                🎮 Go to Menu
              </button>
              <button onClick={()=>{setG(freshGame(["You","Hine-AI","Tūhoe-AI","Rangi-AI"]));setTipId("select");setMS({stolen:false,placed:false,endedTurn:false,aiSeen:false});}}
                style={{padding:"12px 20px",borderRadius:16,fontWeight:700,fontSize:13,border:"2px solid #C9A84C",background:"rgba(0,0,0,.5)",color:"#C9A84C",cursor:"pointer",fontFamily:"inherit"}}>
                🔄 Play Again
              </button>
            </div>
          </div>
        </div>
      )}

      {/* MAIN TABLE */}
      <div style={{position:"relative",zIndex:2,flex:1,display:"flex",flexDirection:"column",padding:"10px 12px 0",paddingBottom:140}}>

        {/* Tutorial tip bar */}
        {tipId!=="welcome" && tipId!=="done" && (
          <div style={{borderRadius:16,border:`2px solid ${accentColor}`,background:`${accentColor}18`,padding:"10px 14px",marginBottom:10,position:"relative",display:"flex",gap:12,alignItems:"flex-start"}}>
            <div style={{flex:1}}>
              <div style={{fontSize:12,fontWeight:900,color:accentColor,marginBottom:3}}>{tip.title}</div>
              <div style={{fontSize:10,color:"#d1d5db",lineHeight:1.5}}>{tip.body}</div>
            </div>
            <button onClick={onSkip}
              style={{flexShrink:0,padding:"4px 12px",borderRadius:10,fontSize:9,fontWeight:700,border:`1px solid ${accentColor}`,background:"rgba(0,0,0,.5)",color:"#9ca3af",cursor:"pointer",fontFamily:"inherit",whiteSpace:"nowrap"}}>
              Skip Tutorial
            </button>
          </div>
        )}

        {/* Header */}
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10,gap:6}}>
          <div>
            <div style={{fontSize:18,fontWeight:900,letterSpacing:".15em",color:"#C9A84C",textShadow:"0 0 16px rgba(201,168,76,.75),3px 3px 0 #4a0000"}}>✦ RAUPATU ✦</div>
            <div style={{fontSize:8,color:"#fbbf24",letterSpacing:".15em"}}>TUTORIAL MODE · VS AI</div>
          </div>
          <div style={{display:"flex",gap:8,alignItems:"center"}}>
            <div style={{fontSize:10,color:"#fcd34d",background:"rgba(0,0,0,.6)",padding:"3px 10px",borderRadius:10,border:"1px solid #78350f"}}>🃏 <b style={{color:"#fff"}}>{G.deck.length}</b></div>
            <div style={{fontSize:11,fontWeight:700,padding:"3px 12px",borderRadius:12,background:myTurn?"#065f46":"#4a1010",color:myTurn?"#fff":"#fca5a5"}}>
              {myTurn?"⚡ YOUR TURN":`🤖 ${G.players[G.turn]?.name}…`}
            </div>
            <button onClick={onSkip} style={{padding:"3px 10px",borderRadius:8,fontSize:10,fontWeight:700,border:"1px solid #6b7280",background:"rgba(0,0,0,.5)",color:"#9ca3af",cursor:"pointer",fontFamily:"inherit"}}>
              Skip
            </button>
          </div>
        </div>

        {/* AI boxes */}
        <div style={{display:"flex",justifyContent:"center",gap:14,marginBottom:10}}>
          {G.players.slice(1).map(p=>(
            <PlayerBox key={p.id} player={p} isActiveTurn={G.turn===p.id}
              selCard={myTurn?selCard:null} mode={G.mode} frozenPiles={G.frozenPiles}
              myPid={0} onClick={()=>clickBox(p.id)}/>
          ))}
        </div>

        {/* Centre */}
        <div style={{display:"flex",justifyContent:"center",alignItems:"center",gap:28,flex:1,minHeight:0,paddingBottom:8}}>
          <PlayerBox player={G.players[0]} isActiveTurn={myTurn}
            selCard={myTurn?selCard:null} mode={G.mode} frozenPiles={G.frozenPiles}
            myPid={0} onClick={()=>clickBox(0)}/>
          <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:5}}>
            <div style={{fontSize:9,color:"#fbbf24",fontWeight:700,letterSpacing:".1em"}}>DRAW PILE</div>
            <div style={{position:"relative",width:66,height:96}}>
              {G.deck.length>2&&<div style={{position:"absolute",width:58,height:84,top:8,left:8,borderRadius:9,border:"3px solid #78350f",background:"#1a3a5c",zIndex:0}}/>}
              {G.deck.length>1&&<div style={{position:"absolute",width:58,height:84,top:4,left:4,borderRadius:9,border:"3px solid #78350f",background:"#1c3d62",zIndex:1}}/>}
              <div style={{position:"absolute",top:0,left:0,zIndex:2}}>{G.deck.length>0?<PCard faceDown/>:<div style={{width:58,height:84,borderRadius:9,border:"2px dashed #a16207",display:"flex",alignItems:"center",justifyContent:"center",color:"#a16207",fontSize:10,opacity:.5}}>EMPTY</div>}</div>
            </div>
            <div style={{fontSize:9,color:"#fcd34d"}}>{G.deck.length} cards</div>
          </div>
          {myTurn&&G.cardsUsed>0&&<div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:3}}><div style={{fontSize:8,color:"#9ca3af"}}>USED</div><div style={{fontSize:22,fontWeight:900,color:"#93c5fd",lineHeight:1}}>{G.cardsUsed}</div><div style={{fontSize:9,color:"#34d399"}}>→draw</div></div>}
        </div>

        {/* End turn */}
        {canEnd&&(
          <div style={{display:"flex",justifyContent:"center",marginBottom:8}}>
            <button onClick={doEndTurn} style={{padding:"9px 28px",borderRadius:18,fontWeight:900,fontSize:13,border:`3px solid ${accentColor}`,background:"linear-gradient(135deg,#92400e,#d97706)",color:"#fff",cursor:"pointer",fontFamily:"inherit",boxShadow:`0 0 14px 5px ${accentColor}55`,animation:"gpulse 1s infinite"}}>
              ↩️ End Turn &amp; Draw {G.cardsUsed}
            </button>
          </div>
        )}

        {/* Scoreboard */}
        <div style={{display:"flex",gap:6,marginBottom:6}}>
          {G.players.map(p=><div key={p.id} style={{flex:1,borderRadius:10,padding:"5px 6px",border:`2px solid ${SEAT[p.id%4].ring}`,background:"rgba(0,0,0,.45)",textAlign:"center"}}><div style={{fontSize:8,color:"#d1d5db",fontWeight:700}}>{p.name}</div><div style={{fontSize:14,color:"#34d399",fontWeight:900}}>{p.hand.length}</div><div style={{fontSize:7,color:"#6b7280"}}>in hand</div></div>)}
        </div>

        <GameLog lines={G.log}/>
      </div>

      {/* Table edge + hand */}
      <div style={{position:"fixed",bottom:0,left:0,right:0,zIndex:10}}>
        <div style={{display:"flex",justifyContent:"center",marginBottom:4}}>
          <div style={{fontSize:9,color:SEAT[0].label,letterSpacing:".12em",fontWeight:700,background:"rgba(0,0,0,.8)",padding:"2px 12px",borderRadius:8,border:`1px solid ${SEAT[0].ring}`}}>
            YOUR HAND ({me.hand.length})
            {G.mode==="steal"&&<span style={{color:"#34d399",marginLeft:6}}>· {G.stealsCount} steal{G.stealsCount>1?"s":""} — end turn or steal more</span>}
            {!G.mode&&myTurn&&<span style={{color:accentColor,marginLeft:6}}>· Steal freely OR place 1</span>}
            {!myTurn&&<span style={{color:"#6b7280",marginLeft:6}}>· AI is playing…</span>}
          </div>
        </div>
        <div style={{height:18,background:"linear-gradient(180deg,#3b1f0a 0%,#5c2d0e 40%,#7a3d14 100%)",borderTop:"3px solid #a0522d",boxShadow:"0 -4px 18px rgba(0,0,0,.7),inset 0 2px 6px rgba(255,200,100,.1)",position:"relative"}}>
          {[12,28,48,68,84].map(pct=><div key={pct} style={{position:"absolute",top:3,bottom:3,left:`${pct}%`,width:1,background:"rgba(0,0,0,.15)",borderRadius:1}}/>)}
        </div>
        <div style={{background:"linear-gradient(180deg,#1a0d04 0%,#110800 100%)",paddingBottom:10,display:"flex",justifyContent:"center",boxShadow:"inset 0 4px 14px rgba(0,0,0,.8)"}}>
          <div style={{display:"flex",gap:10,paddingLeft:16,paddingRight:16}}>
            {me.hand.map((card,i)=>(
              <div key={card.id} style={{marginTop:G.sel===i?-56:-28,transition:"margin-top .18s ease"}}>
                <PCard card={card} greenGlow={G.sel===null&&myTurn&&handCardGlows(card)} onClick={myTurn?()=>selectCard(i):undefined}/>
              </div>
            ))}
            {Array.from({length:Math.max(0,3-me.hand.length)}).map((_,i)=><div key={i} style={{width:58,height:84,marginTop:-28,borderRadius:9,border:"2px dashed rgba(100,200,100,.07)"}}/>)}
          </div>
        </div>
      </div>
      <style>{`@keyframes gpulse{0%,100%{opacity:1}50%{opacity:.3}}`}</style>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════════════════
// APP ROUTER  (tutorial on first launch)
// ═══════════════════════════════════════════════════════════════════════════
export default function App(){
  const tutDone = typeof localStorage !== "undefined" && localStorage.getItem("raupatu_tut");
  const [screen,setScreen]=useState(tutDone ? "menu" : "tutorial");
  const [session,setSession]=useState(null);
  const [gameInit,setGameInit]=useState(null);

  function finishTutorial(){ localStorage.setItem("raupatu_tut","1"); setScreen("menu"); }

  const felt={width:"100%",minHeight:"100vh",fontFamily:"Georgia,serif",
    background:"radial-gradient(ellipse at 50% 35%,#1c4f1c 0%,#0e2d0e 55%,#061406 100%)"};

  if(screen==="tutorial") return <TutorialGame onDone={finishTutorial} onSkip={finishTutorial}/>;
  if(screen==="menu") return <div style={felt}><MainMenu onRules={()=>setScreen("rules")} onFree={()=>setScreen("free")} onPremium={()=>setScreen("premium")} onTutorial={()=>setScreen("tutorial")}/></div>;
  if(screen==="rules") return <div style={felt}><MainMenu onRules={()=>setScreen("rules")} onFree={()=>setScreen("free")} onPremium={()=>setScreen("premium")} onTutorial={()=>setScreen("tutorial")}/><RulesModal onClose={()=>setScreen("menu")}/></div>;
  if(screen==="free") return <div style={felt}><FreeLobby onBack={()=>setScreen("menu")} onEnterRoom={s=>{setSession(s);setScreen("waiting");}}/></div>;
  if(screen==="premium") return <div style={felt}><PremiumLobby onBack={()=>setScreen("menu")} onEnterRoom={s=>{setSession(s);setScreen("waiting");}}/></div>;
  if(screen==="waiting") return <div style={felt}><WaitingRoom session={session} onStart={g=>{setGameInit(g);setScreen("game");}} onLeave={()=>{setSession(null);setScreen("menu");}}/></div>;
  if(screen==="game") return <GameTable initGame={gameInit} session={session} onLeave={()=>{setSession(null);setGameInit(null);setScreen("menu");}}/>;
  return null;
}
