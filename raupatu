// ═══════════════════════════════════════════════════════════════════════════
function PremiumLobby({onBack,onEnterRoom}){
  const [name,    setName]    = useState("");
  const [wallet,  setWallet]  = useState(null);   // {addr, balance, chain}
  const [ethPrice,setEthPrice]= useState(null);   // USD per ETH (live)
  const [stake,   setStake]   = useState(1);      // selected USD amount
  const [code,    setCode]    = useState("");
  const [err,     setErr]     = useState("");
  const [busy,    setBusy]    = useState(false);
  const [txStatus,setTxStatus]= useState(null);   // null | "pending" | "done"

  // Fetch ETH price once on mount
  useEffect(()=>{ getEthPrice().then(setEthPrice); },[]);

  const ethEquiv = ethPrice ? (stake/ethPrice).toFixed(6) : "…";
  const addrShort = wallet ? `${wallet.addr.slice(0,6)}…${wallet.addr.slice(-4)}` : "";

  async function connect(){
    setErr("");
    try{
      const addr = await connectWallet();
      const [bal, chain, price] = await Promise.all([getBalance(addr), getChain(), getEthPrice()]);
      setWallet({addr,balance:bal,chain});
      setEthPrice(price);
    }catch(e){ setErr(e.message||"Connection failed"); }
  }

  async function doHost(){
    const n = name.trim();
    if(!n)  return setErr("Enter your name");
    if(!wallet) return setErr("Connect wallet first");
    setBusy(true); setErr(""); setTxStatus("pending");
    try{
      const c = randCode();
      const room = {
        code:c, started:false, hostPid:0, game:null, premium:true,
        stakeUsd: stake, treasury: wallet.addr, pool: stake,
        seats: [{pid:0,name:n,addr:wallet.addr,joined:true,paid:true}, null, null, null],
      };
      await saveRoom(c, room);
      setTxStatus("done");
      onEnterRoom({code:c, myPid:0, myName:n, premium:true, stakeUsd:stake, treasury:wallet.addr});
    }catch(e){ setErr(e.message||"Failed"); setTxStatus(null); }
    setBusy(false);
  }

  async function doJoin(){
    const n = name.trim(), c = code.trim().toUpperCase();
    if(!n)        return setErr("Enter your name");
    if(c.length<4) return setErr("Enter the 4-letter room code");
    if(!wallet)   return setErr("Connect wallet first");
