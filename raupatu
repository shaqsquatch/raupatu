// FREE LOBBY
// ═══════════════════════════════════════════════════════════════════════════
function FreeLobby({onBack,onEnterRoom}){
  const [name,setName]=useState(""); const [code,setCode]=useState(""); const [err,setErr]=useState(""); const [busy,setBusy]=useState(false);
  async function doHost(){
    const n=name.trim(); if(!n)return setErr("Enter your name"); setBusy(true); setErr("");
    const c=randCode();
    const room={code:c,seats:[{pid:0,name:n,joined:true},null,null,null],started:false,hostPid:0,game:null,premium:false};
    await saveRoom(c,room); onEnterRoom({code:c,myPid:0,myName:n,premium:false}); setBusy(false);
  }
  async function doJoin(){
    const n=name.trim(),c=code.trim().toUpperCase(); if(!n)return setErr("Enter your name"); if(c.length<4)return setErr("Enter room code");
    setBusy(true); setErr(""); const room=await loadRoom(c);
    if(!room)return(setBusy(false),setErr("Room not found"));
    if(room.started)return(setBusy(false),setErr("Game already started"));
    const slot=room.seats.findIndex(s=>s===null); if(slot===-1)return(setBusy(false),setErr("Room full"));
    room.seats[slot]={pid:slot,name:n,joined:true}; await saveRoom(c,room);
    onEnterRoom({code:c,myPid:slot,myName:n,premium:false}); setBusy(false);
  }
  return(
    <div style={{minHeight:"100vh",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:24,gap:16}}>
      <div style={{textAlign:"center"}}>
        <div style={{fontSize:26,fontWeight:900,color:"#059669",textShadow:"0 0 20px rgba(5,150,105,.5)"}}>🎮 Free Rooms</div>
        <div style={{fontSize:10,color:"#6b7280",marginTop:4}}>No buy-in · Play for fun</div>
      </div>
      <div style={{width:"100%",maxWidth:340,display:"flex",flexDirection:"column",gap:10}}>
        <input value={name} onChange={e=>setName(e.target.value.slice(0,16))} placeholder="Your name…"
          style={{width:"100%",padding:"10px 14px",borderRadius:12,fontSize:14,border:"2px solid #059669",background:"rgba(0,0,0,.6)",color:"#fef3c7",fontFamily:"Georgia,serif",outline:"none",boxSizing:"border-box"}}/>
        <button onClick={doHost} disabled={busy} style={{padding:"12px",borderRadius:14,fontWeight:900,fontSize:15,border:"3px solid #059669",background:"linear-gradient(135deg,#065f46,#047857)",color:"#fff",cursor:"pointer",fontFamily:"inherit"}}>
