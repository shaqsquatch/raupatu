const STAKE_OPTIONS = [1, 2, 5, 10, 20, 50, 100]; // USD

async function connectWallet(){
  if(!window.ethereum) throw new Error("MetaMask not installed. Please install it at metamask.io");
  const accounts = await window.ethereum.request({method:"eth_requestAccounts"});
  return accounts[0];
}
async function getBalance(addr){
  const hex = await window.ethereum.request({method:"eth_getBalance",params:[addr,"latest"]});
  return (parseInt(hex,16)/1e18).toFixed(4);
}
async function getChain(){
  const hex = await window.ethereum.request({method:"eth_chainId"});
  const id = parseInt(hex,16);
  return {1:"Ethereum",137:"Polygon",56:"BSC",8453:"Base",10:"Optimism",42161:"Arbitrum",11155111:"Sepolia"}[id]||`Chain ${id}`;
}
async function getEthPrice(){
  try{
    const r = await fetch("https://api.coingecko.com/api/v3/simple/price?ids=ethereum&vs_currencies=usd");
    const d = await r.json();
    return d?.ethereum?.usd || 3000;
  }catch{ return 3000; } // fallback if fetch blocked
}
function usdToWeiHex(usd, ethPriceUsd){
  const eth = usd / ethPriceUsd;
  const wei = BigInt(Math.round(eth * 1e18));
  return "0x" + wei.toString(16);
}
async function sendStake(fromAddr, toAddr, usd, ethPrice){
  const value = usdToWeiHex(usd, ethPrice);
  const txHash = await window.ethereum.request({
    method:"eth_sendTransaction",
    params:[{from:fromAddr, to:toAddr, value, gas:"0x5208"}],
  });
  return txHash;
}

