// ═══════════════════════════════════════════════════════════════════════════
// GAME CONSTANTS & HELPERS
// ═══════════════════════════════════════════════════════════════════════════
const RANKS = ["A","K","Q","J","10","9","8","7","6","5","4","3","2"];
const SUITS = ["♠","♥","♦","♣"];
const RED   = new Set(["♥","♦"]);
const RV    = r => ({A:14,K:13,Q:12,J:11}[r] ?? +r);
const SEAT  = [
  { ring:"#059669", bg:"#012818", label:"#6ee7b7" },
  { ring:"#be123c", bg:"#3b0010", label:"#fda4af" },
  { ring:"#7c3aed", bg:"#200050", label:"#c4b5fd" },
  { ring:"#0891b2", bg:"#012030", label:"#67e8f9" },
];

const topOf   = p => p.length ? p[p.length-1] : null;
const cloneP  = ps => ps.map(p=>({...p,hand:[...p.hand],pile:[...p.pile]}));
const randCode= ()=>Math.random().toString(36).slice(2,6).toUpperCase();

function makeDeck(){ return RANKS.flatMap(r=>SUITS.map(s=>({r,s,id:r+s}))); }
function shuffle(a){ const b=[...a]; for(let i=b.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[b[i],b[j]]=[b[j],b[i]];} return b; }

// Fill player pid's hand up to 3 cards (or until deck runs out).
// When deck is empty, hand stays as-is (plays out remaining cards).
function fillHand(players, deck, pid) {
  const d = [...deck], ps = cloneP(players);
  while (ps[pid].hand.length < 3 && d.length) { ps[pid].hand.push(d.shift()); }
  return { players: ps, deck: d };
}
// Keep drawBack as alias used in GameTable multiplayer push paths
const drawBack = fillHand;

function nextTurn(G,pid){
  return{...G,turn:(pid+1)%G.players.length,sel:null,mode:null,stealsCount:0,cardsUsed:0,frozenPiles:[]};
}
function maybeOver(G){
  if(G.deck.length>0)return G;
  if(G.players.some(p=>p.hand.length>0))return G;
  const ps=G.players.map(p=>({...p,pile:[]}));
  const best=Math.max(...G.players.map(p=>p.pile.length));
  const tops=G.players.filter(p=>p.pile.length===best);
  const winner=tops.length>1?"Tie":tops[0].name;
  const msg=tops.length>1?`🤝 He ōrite! Tie – ${tops.map(t=>t.name).join(" & ")} (${best} cards)`
    :`🏆 ${winner} wins with ${best} cards!`;
  return{...G,players:ps,phase:"over",winner,log:[...G.log,msg]};
}
function freshGame(names){
  const deck=shuffle(makeDeck());
  return{
    deck,players:names.map((name,id)=>({id,name,hand:deck.splice(0,3),pile:[]})),
    turn:0,sel:null,mode:null,stealsCount:0,cardsUsed:0,frozenPiles:[],phase:"play",winner:null,
    log:["🎮 Tīmata! Raupatu begins.","📖 Steal freely OR place 1 · Stolen piles can't be topped"],
  };
}

// Storage
const RKEY = c=>`raupatu-room-${c}`;
async function loadRoom(c){ try{ const r=await window.storage.get(RKEY(c),true); return r?JSON.parse(r.value):null; }catch{return null;} }
async function saveRoom(c,room){ try{ await window.storage.set(RKEY(c),JSON.stringify(room),true); return true; }catch{return false;} }

